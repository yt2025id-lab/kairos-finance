{
  "name": "kairos-cre-workflow",
  "version": "1.0.0",
  "description": "Chainlink CRE Workflow for Kairos Finance yield optimization",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "simulate:local": "tsx src/test-simulate.ts",
    "simulate": "cre workflow simulate workflow.yaml --target staging-settings",
    "deploy:staging": "cre workflow deploy workflow.yaml --target staging-settings",
    "deploy:production": "cre workflow deploy workflow.yaml --target production-settings",
    "deploy": "npm run deploy:staging"
  },
  "dependencies": {
    "@chainlink/cre-sdk": "^1.1.1",
    "viem": "^2.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
