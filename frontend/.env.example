# ============================================================
# Kairos Finance — Frontend Environment Variables
# Copy this file to .env.local and fill in ALL REQUIRED values
# NEVER commit .env.local to git — it contains secrets
# ============================================================

# ============================================================
# REQUIRED — App will not function without these
# ============================================================

# Privy App ID (CRITICAL - Required for authentication)
# Get one at: https://console.privy.io
# Without this, wallet login will not work
NEXT_PUBLIC_PRIVY_APP_ID=

# KairosVault contract address (ERC-4626 vault on Base)
NEXT_PUBLIC_VAULT_ADDRESS=0x5c4B8427fBF6F398C4F780711507E0AA2dEdc855

# KairosController contract address (strategy executor, CRE receiver)
NEXT_PUBLIC_CONTROLLER_ADDRESS=0x84A7C62dAa0DE17b0f01238443d7aBB942A00bfF

# ============================================================
# Network Configuration
# ============================================================

# Chain ID (8453 = Base Mainnet, 84532 = Base Sepolia Testnet)
# Default to Sepolia for testing
NEXT_PUBLIC_CHAIN_ID=84532

# Base Mainnet RPC (optional, uses fallback if not set)
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org

# Base Sepolia Testnet RPC (optional, uses fallback if not set)
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# ============================================================
# Token Configuration
# ============================================================

# USDC token address on Base
# Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Sepolia: 0x4F6D082b3130745687dd200822280946125570F5 (FaucetUSDC)
NEXT_PUBLIC_USDC_ADDRESS=0x4F6D082b3130745687dd200822280946125570F5

# FaucetUSDC contract address (testnet only)
# On Sepolia: same as USDC_ADDRESS (combined ERC20 + faucet)
# Leave empty for mainnet
NEXT_PUBLIC_FAUCET_ADDRESS=0x4F6D082b3130745687dd200822280946125570F5

# ============================================================
# Strategy Adapters (Base Sepolia Testnet)
# ============================================================

# Aave V3 Strategy Adapter
NEXT_PUBLIC_AAVE_V3_STRATEGY=0xF130CE1Ee13f48FEEBc41a4d0dD0003900C56691

# Compound V3 Strategy Adapter
NEXT_PUBLIC_COMPOUND_V3_STRATEGY=0x9A62F36d290C3A4280C4F7A8A6a51EAA1288cfD4

# Moonwell Strategy Adapter
NEXT_PUBLIC_MOONWELL_STRATEGY=0x19406467cC6E88Bd5F5bC932907c315AcC300Ccc

# Morpho Strategy Adapter
NEXT_PUBLIC_MORPHO_STRATEGY=0x32B6bA1a9Ff550C21027A0C0E39CC9CECd82B0b9

# ============================================================
# Optional — Wallet & DApp Configuration
# ============================================================

# WalletConnect v2 Project ID (optional)
# Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
